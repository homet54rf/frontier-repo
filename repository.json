"fastfetch": {
    "version": "2.58.0",
    "description": "A lightning-fast, highly customizable system info script.",
    "url": "https://github.com/fastfetch-cli/fastfetch/releases/download/2.58.0/fastfetch-linux-amd64.tar.gz",
    "source_url": "",
    "source_dir": "",
    "dependencies": [],
    "binary_name": "fastfetch-linux-amd64/usr/bin/fastfetch",
    "build_cmds": [],
    "post_install": [
      "mkdir -p /usr/share/frontier /etc/fastfetch /etc/skel/.config/fastfetch",
      "curl -sLo /usr/share/frontier/logo.png https://raw.githubusercontent.com/homet54rf/frontier-repo/main/configs/frontier-logo.png",
      "curl -sLo /etc/fastfetch/config.jsonc https://raw.githubusercontent.com/homet54rf/frontier-repo/main/configs/config.jsonc",
      "cp /etc/fastfetch/config.jsonc /etc/skel/.config/fastfetch/config.jsonc",
      "chmod 644 /usr/share/frontier/logo.png"
    ]
  }
